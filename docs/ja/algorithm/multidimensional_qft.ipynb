    "@qmc.qkernel\n",
    "def qft_for_multidimension(inputs: qmc.Vector[qmc.Float]) -> qmc.Vector[qmc.Bit]:\n",
    "    N = Nqx + Nqy\n",
    "    q = qmc.qubit_array(N, name=\"q\")\n",
    "    q = amplitude_encoding(q, inputs)  \n",
    "    q[0:Nqx] = qmc.qft(q[0:Nqx])\n",
    "    q[Nqx:N] = qmc.qft(q[Nqx:N])\n",
    "    return qmc.measure(q)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "592ae28c",
