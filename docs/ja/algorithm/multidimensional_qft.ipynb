    "def w5(N: int) -> np.ndarray:\n",
    "    a = np.array([0.1881, 0.36923, 0.28702, 0.13077, 0.02488])\n",
    "    n = np.arange(N)\n",
    "    results = [(-1) ** k * a[k] * np.cos(2 * np.pi * k * n / N) for k in range(5)]\n",
    "    return sum(results)\n",
    "\n",
    "wx = w5(Nx_target)\n",
    "wy = w5(Ny_target)\n",
    "w2d = wx[:, None] * wy[None, :]"
   ]
